# ── Agentix Configuration ─────────────────────────────────────────────────

# Required: Your OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: Override the base URL (e.g. for Azure OpenAI or local LLM via LiteLLM)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-4o)
# LLM_MODEL=gpt-4o

# Optional: Directory where generated projects are stored (default: ./projects)
# PROJECTS_DIR=projects

# Optional: Maximum debug attempts before giving up (default: 3)
# MAX_DEBUG_ATTEMPTS=3

# Optional: Execution timeout in seconds (default: 30)
# EXECUTION_TIMEOUT=30

# Optional: Port to run on (default: 8000)
# PORT=8000
